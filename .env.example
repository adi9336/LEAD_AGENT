# ---- Alert routing ----
ALERT_RECIPIENT_PHONE=+15550000001
REVIEWER_PHONE=+15550000002

# ============================================================
# Security
# ============================================================
# Shared secret monday.com sends in the webhook header. Empty = unverified (dev only).
WEBHOOK_SECRET=

# Bearer token required for admin endpoints /leads and /audit.
ADMIN_TOKEN=change-me

# ---- LLM (live scoring only) ----
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# ---- LangSmith tracing (optional but recommended) ----
# NOTE: the SDK gates the `traceable` decorator on LANGCHAIN_TRACING_V2=true
# (LANGSMITH_TRACING alone is not enough in langsmith>=0.1).
LANGCHAIN_TRACING_V2=true
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=LEAD_AGENT
# LANGSMITH_API_KEY=lsv2_xxx   # required for tracing (your LangSmith key)
