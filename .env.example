# ============================================================
# Beyond Oil — Lead Qualification Agent  (copy to .env)
# ============================================================
# Default config runs the FULL pipeline locally with ZERO
# credentials (mock adapters + SQLite). Fill the LIVE section
# only when you have real credentials.

# ---- Runtime mode ----
# mock  = no external calls (log-backed adapters, rules engine)
# live  = real monday.com + WhatsApp via the adapters below
ADAPTER_MODE=mock

# LLM scoring / integrations are now DECOUPLED:
#   ADAPTER_MODE controls ONLY monday/WhatsApp (mock = log-stubs, no CRM needed).
#   LLM scoring turns on automatically when OPENAI_API_KEY is set. To force it
#   on/off regardless of key, set USE_LLM=true or USE_LLM=false.
USE_LLM=

# WhatsApp transport when ADAPTER_MODE=live
#   whatsapp = Meta WhatsApp Cloud API
#   twilio   = Twilio WhatsApp
ALERT_PROVIDER=whatsapp

# ---- Database ----
# SQLite is fine for local/dev. For prod set a Postgres URL:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/leads
DATABASE_URL=sqlite:///./lead_agent.db

# ---- Scheduler (live mode) ----
REDIS_URL=redis://localhost:6379/0

# ---- Scoring queue reliability ----
# Scoring runs on a Celery queue (when Redis is available) and retries the LLM
# with exponential backoff, so transient failures are retried for a REAL score
# instead of silently falling back to rules.
SCORE_MAX_RETRIES=5
SCORE_RETRY_BACKOFF=15

# ---- SLA targets (see plan.md / Agent.md) ----
SLA_SCORE_MINUTES=5
SLA_ALERT_MINUTES=2
SLA_UNSCORED_HOURS=24
HYGIENE_INTERVAL_MINUTES=60

# ============================================================
# LIVE integrations (leave blank in mock mode)
# ============================================================

# --- monday.com (token should be scoped to a SINGLE board) ---
MONDAY_API_TOKEN=eyJhbGciOiJIUzI1NiJ9.eyJ0aWQiOjY4MTQzNDcyMiwiYWFpIjoxMSwidWlkIjoxMDg1MjMzNzAsImlhZCI6IjIwMjYtMDctMTFUMTQ6MTU6NDQuMTQwWiIsInBlciI6Im1lOndyaXRlIiwiYWN0aWQiOjM1OTYyNDUyLCJyZ24iOiJhcHNlMiJ9.FX-B-UUYM2i7aKSAF-PfPUVCFsLlwCkwuVf_ccQe75E
MONDAY_BOARD_ID=5029839272
