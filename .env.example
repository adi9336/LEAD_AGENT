# --- WhatsApp Cloud API (token scoped to ONE phone number id) ---
WHATSAPP_TOKEN=EAAUEqtL8fnsBR8GnEKfGZAoHZBf2MQl8qdWnz4A4pGALgZCZCjPbcDm7nWusGkY5d71hbskxA1msH0PMmvxiKOe1Scf6LSc5qCDsV3nGbvRR2kKRCrsYBVVZCxfx4XB3ZAVd0qCbx84IMhSGyXdQxHI5F49BZCvTFDkhZCbExqw3BsOEMIqGKNqg9CZAdhxh4OwEdZAFNZBsBoJv82I2FsPKlZATSDpo0Ib9WQ1z1vLBq74GG70nF6xuzFZChpSnLIeOWDvZBxXXpOEaD7qYJUbBfgQ6wZAgonh
